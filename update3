        .vsync_pulse_width = 10,
        .vsync_front_porch = 12,
    },
    .flags.use_dma2d  = true,
};
```

### EK79007 Panel Instantiation

```c
ek79007_vendor_config_t vendor = {
    .mipi_config = {
        .dsi_bus    = dsi_bus,
        .dpi_config = &dpi_cfg,
    },
};
