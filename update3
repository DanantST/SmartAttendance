### LVGL Display Attachment

```c
const lvgl_port_display_cfg_t disp_cfg = {
    .io_handle      = mipi_dbi_io,
    .panel_handle   = display,
    .control_handle = display,
    .buffer_size    = (1024 * 600 * ((16 + 7) / 8)),   // full frame buffer
    .double_buffer  = true,
    .hres           = 1024,
    .vres           = 600,
    .monochrome     = false,
    .rotation       = { .swap_xy = false, .mirror_x = false, .mirror_y = false },
    .flags          = {
        .buff_dma    = false,
        .buff_spiram = true,            // buffers in PSRAM
        .sw_rotate   = true,
        .swap_bytes  = false,           // critical for correct color!
        .full_refresh = false,
        .direct_mode  = false,
    },
};
const lvgl_port_display_dsi_cfg_t dsi_cfg = {
    .flags = { .avoid_tearing = false },
};
lv_display_t *lv_disp = lvgl_port_add_disp_dsi(&disp_cfg, &dsi_cfg);
```

> **The `swap_bytes = false` setting is critical.** With `swap_bytes = true`, the red and blue channels were swapped, producing thick green saturation. This was definitively resolved by setting it to `false`.

