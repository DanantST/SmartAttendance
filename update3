esp_lcd_dpi_panel_config_t dpi_cfg = {
    .dpi_clk_src       = MIPI_DSI_DPI_CLK_SRC_DEFAULT,
    .dpi_clock_freq_mhz = 51,            // 51 MHz pixel clock
